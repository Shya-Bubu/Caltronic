      { "component": "ground", "x": 180, "y": 182 },
      { "component": "wire", "x1": 240, "y1": 182, "x2": 240, "y2": 168 },
      { "component": "wire", "x1": 336, "y1": 158, "x2": 370, "y2": 158, "label": "V_o" },
      { "component": "wire", "x1": 220, "y1": 134, "x2": 220, "y2": 50 },
      { "component": "wire", "x1": 220, "y1": 50, "x2": 220, "y2": 20 },
      { "component": "wire", "x1": 220, "y1": 50, "x2": 250, "y2": 50 },
      { "component": "wire", "x1": 220, "y1": 20, "x2": 250, "y2": 20 },
      { "component": "capacitor", "x": 280, "y": 50, "label": "C", "rotation": 90 },
      { "component": "resistor", "x": 280, "y": 20, "label": "R_F", "rotation": 90 },
      { "component": "wire", "x1": 310, "y1": 50, "x2": 350, "y2": 50 },
      { "component": "wire", "x1": 310, "y1": 20, "x2": 350, "y2": 20 },
      { "component": "wire", "x1": 350, "y1": 50, "x2": 350, "y2": 20 },
      { "component": "wire", "x1": 350, "y1": 50, "x2": 350, "y2": 158 },
      { "component": "junction", "x": 220, "y": 134 },
      { "component": "junction", "x": 220, "y": 50 },
      { "component": "junction", "x": 350, "y": 50 },
      { "component": "junction", "x": 350, "y": 158 }
