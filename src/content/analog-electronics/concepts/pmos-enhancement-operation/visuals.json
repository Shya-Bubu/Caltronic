    {
        "id": "pmos-cross-section-img",
        "type": "image",
        "title": "P-Channel Enhancement MOSFET — Cross-Section",
        "src": "/course/analog-electronics/lesson-09/pmos-cross-section.png",
        "caption": "The PMOS structure mirrors the NMOS: p⁺ source and drain regions sit in an n-type substrate. The channel that forms is p-type, conducting through holes."
    },
    {
        "id": "pmos-biased-img",
        "type": "image",
        "title": "PMOS with Induced P-Channel Under Gate Bias",
        "src": "/course/analog-electronics/lesson-09/pmos-biased-channel.png",
        "caption": "With negative VGS applied (gate more negative than source), holes accumulate at the surface forming the p-channel. Current ID flows from source to drain through this channel."
    },
