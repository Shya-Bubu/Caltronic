  {
    "id": "integrator-drift-plot",
    "type": "plotly",
    "title": "Integrator Drift over Time",
    "description": "Why DC offsets are terrifying for integrators: A tiny 1mV offset is integrated linearly over time ($V = 1mV/RC * t$). Eventually the output completely saturates.",
    "traces": [
      {
        "x": [0, 10, 20, 30, 40, 50, 60],
        "y": [0, 2.5, 5.0, 7.5, 10.0, 12.5, 15.0],
