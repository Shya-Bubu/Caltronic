[
  {
    "id": "real-opamp-model",
    "type": "circuit-schematic",
    "title": "The Practical Op-Amp Equivalent Circuit",
    "description": "Unlike the ideal model, a real op-amp has finite input impedance (R_in), non-zero output impedance (R_o), and an error voltage source (V_OS) representing internal imbalances.",
    "elements": [
      { "component": "wire", "x1": 50, "y1": 50, "x2": 100, "y2": 50, "label": "V_+" },
      { "component": "wire", "x1": 50, "y1": 150, "x2": 100, "y2": 150, "label": "V_-" },
      { "component": "resistor", "x": 100, "y": 100, "label": "R_{in}", "rotation": 90 },
      { "component": "wire", "x1": 100, "y1": 50, "x2": 100, "y2": 70 },
      { "component": "wire", "x1": 100, "y1": 130, "x2": 100, "y2": 150 },
      { "component": "wire", "x1": 100, "y1": 50, "x2": 150, "y2": 50 },
      { "component": "voltage-source", "x": 180, "y": 50, "label": "V_{OS}" },
      { "component": "wire", "x1": 150, "y1": 50, "x2": 165, "y2": 50 },
      { "component": "wire", "x1": 195, "y1": 50, "x2": 220, "y2": 50 },
      { "component": "wire", "x1": 100, "y1": 150, "x2": 220, "y2": 150 },
      { "component": "wire", "x1": 220, "y1": 50, "x2": 250, "y2": 100 },
      { "component": "wire", "x1": 220, "y1": 150, "x2": 250, "y2": 100 },
      { "component": "wire", "x1": 220, "y1": 50, "x2": 220, "y2": 150 },
      { "component": "voltage-source", "x": 300, "y": 100, "label": "A_{vd}V_d" },
      { "component": "resistor", "x": 360, "y": 100, "label": "R_o" },
      { "component": "wire", "x1": 250, "y1": 100, "x2": 285, "y2": 100 },
      { "component": "wire", "x1": 315, "y1": 100, "x2": 330, "y2": 100 },
      { "component": "wire", "x1": 390, "y1": 100, "x2": 430, "y2": 100, "label": "V_o" },
      { "component": "ground", "x": 300, "y": 140 },
      { "component": "wire", "x1": 300, "y1": 115, "x2": 300, "y2": 140 },
      { "component": "junction", "x": 100, "y": 50 },
      { "component": "junction", "x": 100, "y": 150 }
    ],
    "width": 500,
    "height": 200
  },
  {
