        "line": { "color": "#ffbe0b", "width": 3 }
      },
      {
        "x": [60, 61, 70, 80],
        "y": [15.0, 15.0, 15.0, 15.0],
        "mode": "lines",
        "name": "Saturation (+Vcc)",
        "line": { "color": "#ef476f", "width": 4 }
      }
    ],
    "layout": {
      "xaxis": { "title": "Time (ms)" },
      "yaxis": { "title": "Output Voltage (V)" },
