  {
    "id": "offset-voltage-schematic",
    "type": "circuit-schematic",
    "title": "Modeling Input Offset Voltage (V_OS)",
    "description": "Even if both inputs are grounded, a real op-amp acts as if there is a tiny internal battery (V_OS) connected to one of its input terminals.",
    "elements": [
      { "component": "wire", "x1": 100, "y1": 134, "x2": 120, "y2": 134 },
      { "component": "ground", "x": 100, "y": 134 },
      { "component": "voltage-source", "x": 150, "y": 134, "label": "V_{OS} (1 mV)" },
      { "component": "wire", "x1": 165, "y1": 134, "x2": 210, "y2": 134 },
      { "component": "wire", "x1": 100, "y1": 174, "x2": 210, "y2": 174 },
      { "component": "ground", "x": 100, "y": 174 },
      { "component": "op-amp", "x": 258, "y": 154 },
      { "component": "wire", "x1": 306, "y1": 154, "x2": 350, "y2": 154 },
      { "component": "text", "x": 370, "y": 154, "text": "V_o ≠ 0V" },
      { "component": "wire", "x1": 120, "y1": 134, "x2": 135, "y2": 134 }
    ],
    "width": 450,
    "height": 220
  },
  {
    "id": "falstad-offset-error",
    "type": "falstad-sim",
    "title": "Interactive Offset Error in an Amplifier",
    "description": "This inverting amplifier has its input grounded (0V). The op-amp has an internal 5mV offset error. Because the NON-INVERTING gain is (1 + 100k/1k) = 101, the tiny 5mV error is amplified to roughly 500mV at the output!",
    "circuitText": "$ 1 5e-6 10.20027730826997 50 5 43 5e-11\nv 80 160 80 224 0 0 40 5 0 0 0.5\nr 80 160 176 160 0 1000\nw 176 160 224 160 0\nw 224 160 224 176 0\na 272 192 368 192 8 15 -15 1000000 0 0 100000\nw 224 208 224 256 0\ng 80 224 80 240 0\nw 176 160 176 96 0\nr 176 96 336 96 0 100000\nw 336 96 368 96 0\nw 368 96 368 192 0\nv 224 304 224 256 0 0 40 0.005 0 0 0.5\ng 224 304 224 320 0\nO 368 192 416 192 2 0\nt 203 277 241 277 0 -1 -1 0 5mV Internal Error\no 14 64 0 4098 0.625 0.1 0 2 14 3\n"
  },
  {
    "id": "temperature-drift",
    "type": "plotly",
    "title": "Offset Voltage Drift with Temperature",
    "description": "Offset voltage isn't constant. It changes as the silicon heats up or cools down. This requires complex temperature-compensation circuitry in precision measuring tools.",
    "traces": [
      {
        "x": [-40, -20, 0, 25, 50, 75, 100, 125],
        "y": [1.2, 0.8, 0.5, 0.1, -0.4, -1.0, -1.8, -2.5],
        "mode": "lines+markers",
        "name": "V_{OS} (mV)",
        "line": { "color": "#ef476f", "shape": "spline" }
      }
    ],
    "layout": {
      "xaxis": { "title": "Temperature (°C)" },
      "yaxis": { "title": "Input Offset Voltage (mV)" },
      "title": "Thermal Drift (α = ΔV_{OS} / ΔT)"
    }
  },
