[
  {
    "id": "differential-pair-schematic",
    "type": "circuit-schematic",
    "title": "The BJT Differential Pair",
    "description": "The fundamental building block of an op-amp. Two matched transistors share a common emitter tail current. The output is taken differentially between the two collectors.",
    "elements": [
      { "component": "voltage-source", "x": 160, "y": 0, "label": "+V_CC" },
      { "component": "wire", "x1": 130, "y1": 40, "x2": 190, "y2": 40 },
      { "component": "wire", "x1": 160, "y1": 0, "x2": 160, "y2": 40 },
      { "component": "resistor", "x": 130, "y": 70, "label": "R_C", "rotation": 90 },
      { "component": "resistor", "x": 190, "y": 70, "label": "R_C", "rotation": 90 },
      { "component": "npn", "x": 130, "y": 140, "label": "T1" },
      { "component": "npn", "x": 190, "y": 140, "label": "T2", "flip": true },
      { "component": "wire", "x1": 130, "y1": 100, "x2": 130, "y2": 140 },
      { "component": "wire", "x1": 190, "y1": 100, "x2": 190, "y2": 140 },
      { "component": "wire", "x1": 60, "y1": 140, "x2": 100, "y2": 140, "label": "V_1" },
      { "component": "wire", "x1": 260, "y1": 140, "x2": 220, "y2": 140, "label": "V_2" },
      { "component": "wire", "x1": 130, "y1": 180, "x2": 160, "y2": 180 },
      { "component": "wire", "x1": 190, "y1": 180, "x2": 160, "y2": 180 },
      { "component": "resistor", "x": 160, "y": 210, "label": "R_E", "rotation": 90 },
      { "component": "wire", "x1": 160, "y1": 180, "x2": 160, "y2": 210 },
      { "component": "wire", "x1": 160, "y1": 240, "x2": 160, "y2": 280 },
      { "component": "voltage-source", "x": 160, "y": 280, "label": "-V_CC" },
      { "component": "wire", "x1": 130, "y1": 120, "x2": 190, "y2": 120, "label": "V_o (Diff)" },
      { "component": "junction", "x": 130, "y": 100 },
      { "component": "junction", "x": 190, "y": 100 },
      { "component": "junction", "x": 160, "y": 180 }
    ],
    "width": 320,
    "height": 320
  },
  {
    "id": "ac-half-circuit",
    "type": "circuit-schematic",
    "title": "AC Equivalent Half-Circuit",
    "description": "By exploiting symmetry, we can analyze just one half of the differential pair. The common emitter node becomes an AC ground for differential signals.",
    "elements": [
      { "component": "wire", "x1": 50, "y1": 100, "x2": 100, "y2": 100, "label": "V_d/2" },
      { "component": "resistor", "x": 130, "y": 100, "label": "h_{ie}" },
      { "component": "wire", "x1": 160, "y1": 100, "x2": 200, "y2": 100 },
      { "component": "current-source", "x": 200, "y": 140, "label": "h_{fe} i_b", "rotation": -90 },
      { "component": "wire", "x1": 200, "y1": 100, "x2": 200, "y2": 140 },
      { "component": "wire", "x1": 200, "y1": 100, "x2": 260, "y2": 100 },
      { "component": "resistor", "x": 260, "y": 140, "label": "R_C", "rotation": 90 },
      { "component": "wire", "x1": 260, "y1": 100, "x2": 260, "y2": 140 },
      { "component": "wire", "x1": 260, "y1": 100, "x2": 320, "y2": 100, "label": "V_{o1}" },
      { "component": "ground", "x": 200, "y": 180 },
      { "component": "wire", "x1": 160, "y1": 180, "x2": 260, "y2": 180 },
      { "component": "wire", "x1": 160, "y1": 130, "x2": 160, "y2": 180 }
    ],
    "width": 370,
    "height": 220
  },
  {
    "id": "differential-pair-falstad",
    "type": "falstad-sim",
    "title": "Interactive Differential Pair",
    "description": "Explore the BJT differential pair. Try applying the same signal to both inputs (common mode) vs opposite signals (differential mode) and observe the output.",
    "circuitText": "$ 1 5e-6 10.20027730826997 64 0 0 43\nv 96 160 96 320 0 1 40 5 0 0 0.5\nv 416 160 416 320 0 1 40 -5 0 0 0.5\nR 256 64 256 32 0 0 40 15 0 0 0.5\nR 256 384 256 416 0 0 40 -15 0 0 0.5\nr 192 128 192 64 0 10000\nr 320 128 320 64 0 10000\nw 192 64 256 64 0\nw 320 64 256 64 0\nt 160 160 192 160 0 1 -0.6698162261 0.6121764663 100 default\nt 352 160 320 160 0 -1 -0.6698162261 0.6121764663 100 default\nw 96 160 160 160 0\nw 416 160 352 160 0\nw 192 192 256 192 0\nw 320 192 256 192 0\nr 256 192 256 384 0 10000\ng 96 320 96 352 0 0\ng 416 320 416 352 0 0\nw 192 128 192 160 0\nw 320 128 320 160 0\nO 192 128 256 128 2 0\nO 320 128 256 128 3 0\no 1 64 0 4098 10 0.1 0 2 1 3\no 0 64 0 4098 10 0.1 0 2 0 3\n"
  },
  {
    "id": "ideal-opamp-schematic",
    "type": "circuit-schematic",
    "title": "The Ideal Op-Amp Model",
    "description": "Inside an ideal op-amp: infinite input resistance (open circuit) and zero output resistance (perfect dependent voltage source).",
    "elements": [
      { "component": "wire", "x1": 50, "y1": 80, "x2": 100, "y2": 80, "label": "V_+" },
      { "component": "wire", "x1": 50, "y1": 160, "x2": 100, "y2": 160, "label": "V_-" },
      { "component": "text", "x": 100, "y": 120, "text": "R_in → ∞" },
      { "component": "voltage-source", "x": 240, "y": 120, "label": "A_{vd} V_d", "value": "A_{vd}→∞" },
      { "component": "wire", "x1": 240, "y1": 80, "x2": 240, "y2": 120 },
      { "component": "wire", "x1": 240, "y1": 160, "x2": 240, "y2": 120 },
      { "component": "ground", "x": 240, "y": 160 },
      { "component": "wire", "x1": 240, "y1": 80, "x2": 300, "y2": 80 },
      { "component": "text", "x": 270, "y": 60, "text": "R_o → 0" },
      { "component": "wire", "x1": 300, "y1": 80, "x2": 350, "y2": 80, "label": "V_o" },
      { "component": "arrow", "x": 75, "y": 80, "direction": "right", "label": "i_+ = 0" },
      { "component": "arrow", "x": 75, "y": 160, "direction": "right", "label": "i_- = 0" }
    ],
    "width": 400,
    "height": 200
  },
  {
    "id": "cmrr-curves",
    "type": "plotly",
    "title": "Differential vs. Common-Mode Gain",
    "description": "A logarithmic plot distinguishing the massive differential gain characteristic of an op-amp compared to its extremely tiny common-mode gain.",
    "traces": [
      {
        "x": ["Ideal", "Typical Real"],
        "y": [1e8, 100000],
        "type": "bar",
        "name": "Differential Gain (A_vd)",
        "marker": { "color": "#4ecdc4" }
      },
      {
        "x": ["Ideal", "Typical Real"],
        "y": [1e-8, 0.01],
        "type": "bar",
        "name": "Common-Mode Gain (A_cm)",
        "marker": { "color": "#ff6b6b" }
      }
    ],
    "layout": {
      "yaxis": { "type": "log", "title": "Voltage Gain (V/V)" },
      "barmode": "group",
      "title": "Op-Amp Gains (Log Scale)"
    }
  },
  {
    "id": "virtual-short-demo",
    "type": "plotly",
    "title": "The Virtual Short Principle",
    "description": "Shows how negative feedback forces the differential voltage V_d closer and closer to zero as the open-loop gain A increases. V_d = V_o / A.",
    "traces": [
      {
        "x": [10, 100, 1000, 10000, 100000, 1000000],
        "y": [1.0, 0.1, 0.01, 0.001, 0.0001, 0.00001],
        "mode": "lines+markers",
        "name": "V_d for V_o = 10V",
        "line": { "color": "#ffbe0b", "width": 3 }
      }
    ],
    "layout": {
      "xaxis": { "type": "log", "title": "Open-Loop Gain (A)" },
      "yaxis": { "type": "log", "title": "Differential Voltage V_d (Volts)" },
      "title": "V_d Approaches Zero as Gain Approaches Infinity"
    }
  },
  {
    "id": "current-mirror-schematic",
    "type": "circuit-schematic",
    "title": "Constant Current Source (Current Mirror)",
    "description": "Used to generate the stable tail current I_EE for the differential pair. The reference current is 'mirrored' to the output transistor.",
    "elements": [
      { "component": "voltage-source", "x": 160, "y": 40, "label": "V_{CC}" },
      { "component": "wire", "x1": 100, "y1": 40, "x2": 220, "y2": 40 },
      { "component": "wire", "x1": 160, "y1": 40, "x2": 160, "y2": 80 },
      { "component": "resistor", "x": 100, "y": 80, "label": "R_{ref}", "rotation": 90 },
      { "component": "wire", "x1": 100, "y1": 40, "x2": 100, "y2": 80 },
      { "component": "npn", "x": 100, "y": 140, "label": "T_3" },
      { "component": "npn", "x": 220, "y": 140, "label": "T_4" },
      { "component": "wire", "x1": 100, "y1": 120, "x2": 100, "y2": 140 },
      { "component": "wire", "x1": 220, "y1": 120, "x2": 220, "y2": 140, "label": "I_{EE}" },
      { "component": "wire", "x1": 100, "y1": 140, "x2": 160, "y2": 140 },
      { "component": "wire", "x1": 160, "y1": 140, "x2": 220, "y2": 140 },
      { "component": "wire", "x1": 160, "y1": 140, "x2": 160, "y2": 120 },
      { "component": "wire", "x1": 100, "y1": 120, "x2": 160, "y2": 120 },
      { "component": "wire", "x1": 100, "y1": 180, "x2": 160, "y2": 180 },
      { "component": "wire", "x1": 220, "y1": 180, "x2": 160, "y2": 180 },
      { "component": "ground", "x": 160, "y": 180 },
      { "component": "junction", "x": 100, "y": 120 },
      { "component": "junction", "x": 100, "y": 140 },
      { "component": "junction", "x": 160, "y": 140 },
      { "component": "junction", "x": 160, "y": 40 },
      { "component": "junction", "x": 160, "y": 180 }
    ],
    "width": 320,
    "height": 220
  },
  {
    "id": "ideal-vs-real-table",
    "type": "plotly",
    "title": "Ideal vs Practical Op-Amp Characteristics",
    "description": "Visualizing how close the ideal model approximations are to typical real-world values.",
    "traces": [
      {
        "type": "table",
        "header": {
          "values": ["<b>Parameter</b>", "<b>Ideal Value</b>", "<b>Typical Real Value (e.g. 741)</b>"],
          "align": "left",
          "fill": { "color": "#4ecdc4" },
          "font": { "color": "white", "size": 14 }
        },
        "cells": {
          "values": [
            ["Voltage Gain (A_vd)", "Input Resistance (R_in)", "Output Resistance (R_o)", "Bandwidth (BW)", "CMRR"],
            ["Infinity (∞)", "Infinity (∞)", "Zero (0 Ω)", "Infinity (∞)", "Infinity (∞)"],
            ["100,000 to 1,000,000 V/V", "2 MΩ to 10¹² Ω", "50 Ω to 75 Ω", "1 MHz to 100 MHz", "90 dB to 120 dB"]
          ],
          "align": "left",
          "fill": { "color": ["white", "#f8f9fa", "white", "#f8f9fa", "white"] },
          "font": { "size": 13 }
        }
      }
    ],
    "layout": {
      "title": "Ideal vs. Real Characteristics",
      "height": 250,
      "margin": { "l": 10, "r": 10, "t": 40, "b": 10 }
    }
  }
