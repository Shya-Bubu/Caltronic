        {
            "id": "qpoint-procedure",
            "type": "block-diagram",
            "title": "Systematic Q-Point Procedure (4 Steps)",
            "blocks": [
                {
                    "id": "s1",
                    "label": "Step 1:\nFind VTh, RTh",
                    "position": "left"
                },
                {
                    "id": "s2",
                    "label": "Step 2:\nKVL base loop\n→ IB",
                    "position": "center-left"
                },
                {
                    "id": "s3",
                    "label": "Step 3:\nIC = βIB\nIE = (β+1)IB",
                    "position": "center-right"
                },
                {
                    "id": "s4",
                    "label": "Step 4:\nKVL collector\n→ VCE",
                    "position": "right"
                }
            ],
            "connections": [
                {
                    "from": "s1",
                    "to": "s2"
                },
                {
                    "from": "s2",
                    "to": "s3"
                },
                {
                    "from": "s3",
                    "to": "s4"
                }
            ]
        },
