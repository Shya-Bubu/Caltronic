  {
    "id": "threshold-noise",
    "type": "plotly",
    "title": "The Problem with Basic Comparators: Noise",
    "description": "If the input signal has electrical noise, it might cross the V_ref threshold multiple times rapidly as it passes exactly through 0V. This causes the output to violently chatter between +15V and -15V.",
    "traces": [
      {
        "x": [0, 1, 2, 2.8, 2.9, 3.0, 3.1, 3.2, 4, 5, 6],
        "y": [-5, -3, -1, -0.1, 0.2, -0.1, 0.1, 0.5, 3, 5, 7],
        "mode": "lines",
        "name": "Noisy Input V_in",
        "line": { "color": "#118ab2" }
      },
      {
        "x": [0, 2.85, 2.85, 2.95, 2.95, 3.05, 3.05, 6],
        "y": [-15, -15, 15, 15, -15, -15, 15, 15],
        "mode": "lines",
        "name": "Chattering Output V_o",
        "line": { "color": "#ef476f", "width": 2, "shape": "hv" }
      },
      {
        "x": [0, 6],
        "y": [0, 0],
        "mode": "lines",
        "name": "V_ref (0V)",
        "line": { "color": "gray", "dash": "dash" }
      }
    ],
    "layout": {
      "xaxis": { "title": "Time" },
      "yaxis": { "title": "Voltage (V)" },
      "title": "Multiple Triggering due to Noise"
    }
  },
  {
    "id": "schmitt-trigger-schematic",
    "type": "circuit-schematic",
    "title": "The Schmitt Trigger (Positive Feedback)",
    "description": "By connecting the output back to the NON-INVERTING (+) terminal, we create POSITIVE feedback. This creates two distinct threshold voltages depending on whether the output is currently High or Low.",
    "elements": [
      { "component": "wire", "x1": 60, "y1": 134, "x2": 150, "y2": 134, "label": "V_{in}" },
      { "component": "op-amp", "x": 198, "y": 154 },
      { "component": "wire", "x1": 246, "y1": 154, "x2": 280, "y2": 154, "label": "V_o" },
      { "component": "wire", "x1": 150, "y1": 174, "x2": 120, "y2": 174 },
      { "component": "resistor", "x": 120, "y": 204, "label": "R_2", "rotation": 90 },
      { "component": "wire", "x1": 120, "y1": 174, "x2": 120, "y2": 204 },
      { "component": "wire", "x1": 120, "y1": 264, "x2": 120, "y2": 290 },
      { "component": "ground", "x": 120, "y": 290 },
      { "component": "wire", "x1": 120, "y1": 174, "x2": 90, "y2": 174 },
      { "component": "wire", "x1": 90, "y1": 174, "x2": 90, "y2": 80 },
      { "component": "wire", "x1": 90, "y1": 80, "x2": 120, "y2": 80 },
      { "component": "resistor", "x": 150, "y": 80, "label": "R_1" },
      { "component": "wire", "x1": 180, "y1": 80, "x2": 260, "y2": 80 },
      { "component": "wire", "x1": 260, "y1": 80, "x2": 260, "y2": 154 },
      { "component": "junction", "x": 120, "y": 174 },
      { "component": "junction", "x": 260, "y": 154 },
      { "component": "text", "x": 100, "y": 190, "text": "V_+" }
    ],
    "width": 340,
    "height": 320
  },
  {
    "id": "hysteresis-curve",
    "type": "plotly",
    "title": "Hysteresis Transfer Curve",
    "description": "The output 'snaps' to one state or the other and stays there until the input crosses the opposite threshold. The 'dead zone' between V_TL and V_TU is called the hysteresis band.",
    "traces": [
      {
        "x": [-5, 2, 2, 5],
        "y": [15, 15, -15, -15],
        "mode": "lines",
        "name": "Input increasing (→)",
