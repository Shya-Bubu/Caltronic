      },
      {
        "x": [5, -2, -2, -5],
        "y": [-15, -15, 15, 15],
        "mode": "lines",
        "name": "Input decreasing (←)",
        "line": { "color": "#ef476f", "width": 4, "dash": "dash" }
      },
      {
        "x": [0, 0],
        "y": [-20, 20],
        "mode": "lines",
