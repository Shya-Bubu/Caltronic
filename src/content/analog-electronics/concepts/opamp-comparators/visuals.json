  {
    "id": "comparator-schematic",
    "type": "circuit-schematic",
    "title": "The Basic Comparator",
    "description": "An op-amp operated entirely open-loop (no feedback). It compares V_in against a fixed reference voltage V_ref.",
    "elements": [
      { "component": "wire", "x1": 60, "y1": 134, "x2": 150, "y2": 134, "label": "V_{in}" },
      { "component": "wire", "x1": 60, "y1": 174, "x2": 150, "y2": 174, "label": "V_{ref}" },
      { "component": "op-amp", "x": 198, "y": 154 },
      { "component": "wire", "x1": 246, "y1": 154, "x2": 300, "y2": 154, "label": "V_o" },
      { "component": "wire", "x1": 198, "y1": 104, "x2": 198, "y2": 80 },
      { "component": "voltage-source", "x": 198, "y": 80, "label": "+V_{CC}" },
      { "component": "wire", "x1": 198, "y1": 204, "x2": 198, "y2": 220 },
      { "component": "voltage-source", "x": 198, "y": 220, "label": "-V_{CC}" }
    ],
    "width": 360,
    "height": 280
  },
  {
    "id": "zero-crossing-detector",
    "type": "plotly",
    "title": "Zero-Crossing Detector ($V_{ref} = 0V$)",
    "description": "A very common use case: converting a weak analog sine wave into a robust digital square wave by triggering every time the sine wave crosses 0V.",
    "traces": [
      {
        "x": [0, 1, 2, 3, 4, 5, 6, 7, 8],
        "y": [0, 4, 5.6, 4, 0, -4, -5.6, -4, 0],
        "mode": "lines",
        "name": "V_in (Sine)",
        "line": { "color": "#118ab2", "shape": "spline" }
      },
      {
        "x": [0, 0 , 4, 4, 8, 8],
        "y": [-15, 15, 15, -15, -15, 15],
        "mode": "lines",
        "name": "V_o (Comparator)",
        "line": { "color": "#ef476f", "width": 3, "shape": "hv" }
      },
      {
        "x": [0, 8],
        "y": [0, 0],
        "mode": "lines",
        "name": "V_ref (0V)",
        "line": { "color": "gray", "dash": "dash" }
      }
    ],
    "layout": {
      "xaxis": { "title": "Time" },
      "yaxis": { "title": "Voltage (V)" },
      "title": "Sine to Square Wave Conversion"
    }
  },
  {
    "id": "falstad-comparator",
