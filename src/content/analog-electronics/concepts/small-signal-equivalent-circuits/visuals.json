{
    "visuals": [
        {
            "id": "ac-rules",
            "type": "block-diagram",
            "title": "AC Analysis Rules: Capacitors→Short, VCC→Ground, BJT→h-Param",
            "blocks": [
                {
                    "id": "caps",
                    "label": "Coupling/Bypass Caps\n→ Short Circuit\n(XC ≈ 0 at fSIG)",
                    "position": "left"
                },
                {
                    "id": "vcc",
                    "label": "VCC (DC supply)\n→ AC Ground\n(zero impedance)",
                    "position": "center"
                },
                {
                    "id": "bjt",
                    "label": "BJT\n→ h-Parameter\nModel",
                    "position": "right"
                }
            ],
            "connections": []
        },
        {
            "id": "procedure-flowchart",
            "type": "block-diagram",
            "title": "5-Step Procedure for Drawing AC Small-Signal Equivalent",
            "blocks": [
                {
                    "id": "s1",
                    "label": "1. VCC → Ground",
                    "position": "left"
                },
                {
                    "id": "s2",
                    "label": "2. Short all caps",
                    "position": "center-left"
                },
                {
                    "id": "s3",
                    "label": "3. Redraw circuit\n(R1,RC → GND)",
                    "position": "center"
                },
                {
                    "id": "s4",
                    "label": "4. BJT → h-param\nmodel",
                    "position": "center-right"
                },
                {
                    "id": "s5",
                    "label": "5. Add source\n(vs + Rs)",
                    "position": "right"
                }
            ],
            "connections": [
                {
                    "from": "s1",
                    "to": "s2"
                },
                {
                    "from": "s2",
                    "to": "s3"
                },
                {
                    "from": "s3",
                    "to": "s4"
                },
                {
                    "from": "s4",
                    "to": "s5"
                }
            ]
        },
