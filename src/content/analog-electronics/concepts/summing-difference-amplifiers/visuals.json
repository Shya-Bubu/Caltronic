  {
    "id": "weighted-sum-demo",
    "type": "plotly",
    "title": "Scaling Individual Inputs",
    "description": "By choosing different resistor values, we can weight the inputs differently. Here, V_o = -2*V_1 - 0.5*V_2.",
    "traces": [
      {
        "x": [0, 1, 2, 3, 4, 5, 6],
        "y": [1, 1, 1, 1, 1, 1, 1],
        "mode": "lines+markers",
        "name": "V_1 (Weight 2)",
        "line": { "color": "#118ab2", "dash": "dash" }
      },
      {
        "x": [0, 1, 2, 3, 4, 5, 6],
        "y": [2, 2, 2, 2, 2, 2, 2],
        "mode": "lines+markers",
        "name": "V_2 (Weight 0.5)",
        "line": { "color": "#06d6a0", "dash": "dash" }
      },
      {
        "x": [0, 1, 2, 3, 4, 5, 6],
        "y": [-3, -3, -3, -3, -3, -3, -3],
