{
    "id": "flashcards-solutions-q3-q4",
    "cards": [
        {
            "id": "f1",
            "front": "Q3: hfe from graph procedure?",
            "back": "At constant VCE (Q-point), read IC at two IB curves. hfe = ΔIC/ΔIB ≈ (10−6)mA/(100−60)μA = 100.",
            "difficultyLevel": 3
        },
        {
            "id": "f2",
            "front": "Q3: DC load line x-intercept?",
            "back": "VCE = VCC = 15V (when IC = 0).",
            "difficultyLevel": 1
        },
        {
            "id": "f3",
            "front": "Q3: AC load line x-intercept?",
            "back": "VCE = VCEQ + ICQ×RAC = 8 + 8mA×680Ω = 13.44V.",
            "difficultyLevel": 2
        },
        {
            "id": "f4",
            "front": "Q3: Why is the output waveform asymmetric?",
            "back": "IB swings from −10μA to 170μA. Since IB can't go below 0 (cutoff), negative half is clipped at VCE=13.44V.",
            "difficultyLevel": 3
        },
        {
            "id": "f5",
            "front": "Q4: Why CE then CC?",
            "back": "CE provides high voltage gain. CC provides unity gain but very high Rin (doesn't load CE) and very low Rout (drives load).",
            "difficultyLevel": 2
        },
        {
            "id": "f6",
            "front": "Q4 Stage 1: Ai1?",
            "back": "Ai1 = −hfe/(1+hoe·RC) = −50/1.25 = −40.",
            "difficultyLevel": 3
        },
        {
            "id": "f7",
            "front": "Q4 Stage 1: Av1?",
            "back": "Av1 = Ai1×RC/hie = −40×10000/1100 = −363.6.",
            "difficultyLevel": 3
        },
        {
            "id": "f8",
            "front": "Q4 Stage 2: Rin2?",
            "back": "Rin2 = hic − hrc·hfc·RE/(1+hoc·RE) = 1100 + 255000/1.125 ≈ 228 kΩ. Very high!",
            "difficultyLevel": 3
        },
        {
            "id": "f9",
            "front": "Q4 Stage 2: Rout2?",
            "back": "Rout2 ≈ hic/|hfc| = 1100/51 ≈ 21.6 Ω. Very low!",
            "difficultyLevel": 2
        },
        {
            "id": "f10",
            "front": "Q4: Overall voltage gain?",
            "back": "Avs = [Rin1/(Rin1+Rs)] × Av1(loaded) × Av2 ≈ 0.5 × (−435) × 1 ≈ −217.",
            "difficultyLevel": 3
        }
    ]
}