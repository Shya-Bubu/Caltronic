  {
    "id": "kcl-current-flow",
    "type": "circuit-schematic",
    "title": "KCL at the Virtual Ground",
    "description": "All the current that flows through R1 MUST flow through R2, because the op-amp input draws zero current. This simple fact defines the entire amplifier.",
    "elements": [
      { "component": "wire", "x1": 50, "y1": 150, "x2": 100, "y2": 150, "label": "V_{in}" },
      { "component": "resistor", "x": 130, "y": 150, "label": "R_1" },
      { "component": "wire", "x1": 160, "y1": 150, "x2": 220, "y2": 150 },
      { "component": "text", "x": 220, "y": 170, "text": "Node A (0V)" },
      { "component": "op-amp", "x": 268, "y": 174 },
      { "component": "wire", "x1": 220, "y1": 150, "x2": 220, "y2": 164 },
      { "component": "wire", "x1": 180, "y1": 198, "x2": 220, "y2": 198 },
      { "component": "ground", "x": 180, "y": 198 },
      { "component": "wire", "x1": 220, "y1": 198, "x2": 220, "y2": 184 },
      { "component": "wire", "x1": 316, "y1": 174, "x2": 350, "y2": 174, "label": "V_o" },
      { "component": "wire", "x1": 200, "y1": 150, "x2": 200, "y2": 90 },
      { "component": "wire", "x1": 200, "y1": 90, "x2": 230, "y2": 90 },
      { "component": "resistor", "x": 260, "y": 90, "label": "R_2" },
      { "component": "wire", "x1": 290, "y1": 90, "x2": 330, "y2": 90 },
      { "component": "wire", "x1": 330, "y1": 90, "x2": 330, "y2": 174 },
      { "component": "junction", "x": 200, "y": 150 },
      { "component": "junction", "x": 330, "y": 174 },
      { "component": "arrow", "x": 80, "y": 150, "direction": "right", "label": "I_1" },
      { "component": "arrow", "x": 210, "y": 90, "direction": "right", "label": "I_2" },
      { "component": "arrow", "x": 210, "y": 164, "direction": "right", "label": "i_- = 0" },
      { "component": "text", "x": 260, "y": 60, "text": "I_1 = I_2", "color": "#ff6b6b" }
    ],
    "width": 400,
    "height": 260
