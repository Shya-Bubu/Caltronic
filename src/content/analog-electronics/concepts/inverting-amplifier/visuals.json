[
  {
    "id": "inverting-amp-schematic",
    "type": "circuit-schematic",
    "title": "The Inverting Amplifier",
    "description": "The standard inverting amplifier configuration. The input signal V_in is applied through R1 to the inverting terminal, and R2 provides negative feedback from the output.",
    "elements": [
      { "component": "wire", "x1": 60, "y1": 120, "x2": 100, "y2": 120, "label": "V_{in}" },
      { "component": "resistor", "x": 130, "y": 120, "label": "R_1" },
      { "component": "wire", "x1": 160, "y1": 120, "x2": 240, "y2": 120 },
      { "component": "op-amp", "x": 288, "y": 144 },
      { "component": "wire", "x1": 240, "y1": 120, "x2": 240, "y2": 134 },
      { "component": "wire", "x1": 180, "y1": 168, "x2": 240, "y2": 168 },
      { "component": "ground", "x": 180, "y": 168 },
      { "component": "wire", "x1": 240, "y1": 168, "x2": 240, "y2": 154 },
      { "component": "wire", "x1": 336, "y1": 144, "x2": 370, "y2": 144, "label": "V_o" },
      { "component": "wire", "x1": 220, "y1": 120, "x2": 220, "y2": 60 },
      { "component": "wire", "x1": 220, "y1": 60, "x2": 250, "y2": 60 },
      { "component": "resistor", "x": 280, "y": 60, "label": "R_2" },
      { "component": "wire", "x1": 310, "y1": 60, "x2": 350, "y2": 60 },
      { "component": "wire", "x1": 350, "y1": 60, "x2": 350, "y2": 144 },
      { "component": "junction", "x": 220, "y": 120 },
      { "component": "junction", "x": 350, "y": 144 },
      { "component": "text", "x": 200, "y": 140, "text": "A" }
    ],
    "width": 420,
    "height": 220
  },
  {
