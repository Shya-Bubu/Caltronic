  {
    "id": "gain-vs-resistors",
    "type": "plotly",
    "title": "Gain Control via Resistor Ratio",
    "description": "The magnitude of the closed-loop gain |A_v| = R_2 / R_1. By simply changing a resistor, you can set the gain to an exact, precise value.",
    "traces": [
      {
        "x": [0.1, 1, 2, 5, 10, 20, 50, 100],
        "y": [0.1, 1, 2, 5, 10, 20, 50, 100],
        "mode": "lines+markers",
        "name": "Gain Magnitude |A_v|",
        "line": { "color": "#4ecdc4", "width": 3 }
      }
    ],
    "layout": {
      "xaxis": { "title": "Resistor Ratio (R_2 / R_1)", "type": "log" },
      "yaxis": { "title": "Voltage Gain Magnitude |V_o / V_in|", "type": "log" },
      "title": "Closed-Loop Gain Depends ONLY on Resistors"
    }
  },
  {
    "id": "transfer-characteristic",
    "type": "plotly",
    "title": "Inverting Amplifier Transfer Characteristic",
    "description": "Because of the negative sign, the slope of the V_out vs V_in graph is negative. The output is bounded by the supply rails (±15V here).",
    "traces": [
      {
        "x": [-5, -1.5, 0, 1.5, 5],
        "y": [15, 15, 0, -15, -15],
        "mode": "lines",
        "name": "Gain = -10",
        "line": { "color": "#ff6b6b", "width": 3 }
      },
      {
        "x": [-5, -5, 5, 5],
        "y": [15, 15, 15, 15],
        "mode": "lines",
        "line": { "color": "gray", "dash": "dash" },
        "name": "+15V Rail"
      },
      {
        "x": [-5, -5, 5, 5],
        "y": [-15, -15, -15, -15],
        "mode": "lines",
        "line": { "color": "gray", "dash": "dash" },
        "name": "-15V Rail"
      }
