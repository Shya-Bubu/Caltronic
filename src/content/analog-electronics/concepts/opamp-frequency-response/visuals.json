  {
    "id": "gain-bandwidth-product",
    "type": "plotly",
    "title": "The Constant Gain-Bandwidth Product (GBP)",
    "description": "For a standard voltage-feedback op-amp, the product of Gain × Bandwidth is always exactly the same constant number. For the venerable LM741, GBP = 1 MHz.",
    "traces": [
      {
        "x": ["Gain=100k, BW=10Hz", "Gain=10k, BW=100Hz", "Gain=1k, BW=1kHz", "Gain=100, BW=10kHz", "Gain=10, BW=100kHz", "Gain=1, BW=1MHz"],
        "y": [1000000, 1000000, 1000000, 1000000, 1000000, 1000000],
        "type": "bar",
        "name": "Gain × Bandwidth",
        "marker": { "color": "#ef476f" }
      }
    ],
    "layout": {
      "yaxis": { "title": "Product Value (Hz)", "range": [0, 1200000] },
      "title": "GBP = Gain × Bandwidth = Constant"
    }
  },
  {
    "id": "temperature-stability",
    "type": "plotly",
    "title": "Stabilizing Gain against Temperature",
    "description": "The open-loop gain A_d fluctuates wildly with temperature as internal transistor betas change. But thanks to the equation A_f ≈ 1/β, the closed-loop gain is rock solid because it depends entirely on stable external resistors.",
    "traces": [
      {
        "x": [-20, 0, 25, 50, 75, 100],
        "y": [80000, 90000, 100000, 115000, 130000, 150000],
        "mode": "lines+markers",
        "name": "Open-Loop Gain A_d",
        "line": { "color": "#ffbe0b", "width": 2 }
      },
      {
        "x": [-20, 0, 25, 50, 75, 100],
        "y": [100, 100, 100, 100, 100, 100],
        "mode": "lines+markers",
        "name": "Closed-Loop Gain A_f",
        "yaxis": "y2",
        "line": { "color": "#118ab2", "width": 4 }
      }
    ],
    "layout": {
      "xaxis": { "title": "Temperature (°C)" },
      "yaxis": { "title": "Open-Loop Gain", "range": [50000, 200000] },
      "yaxis2": { "title": "Closed-Loop Gain", "overlaying": "y", "side": "right", "range": [99, 101] },
      "title": "Gain Stability vs Temperature"
    }
  },
